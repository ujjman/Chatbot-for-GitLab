# Required
FIRECRAWL_API_KEY=fc-your-firecrawl-key
GROQ_API_KEY=your-groq-api-key

# Optional model overrides
GROQ_CHAT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Optional Firecrawl MCP process settings
FIRECRAWL_MCP_COMMAND=npx
FIRECRAWL_MCP_ARGS=-y,firecrawl-mcp
FIRECRAWL_MCP_TIMEOUT_SECONDS=120
FIRECRAWL_MAX_PAGES=100

# Optional Windows fallback if npx launch has issues:
# FIRECRAWL_MCP_COMMAND=cmd
# FIRECRAWL_MCP_ARGS=/c,npx,-y,firecrawl-mcp

# Optional source overrides
HANDBOOK_ROOT_URL=https://handbook.gitlab.com/handbook/
DIRECTION_URL=https://about.gitlab.com/releases/whats-new/#whats-coming
